# Porta de execução do servidor (opcional, Hostinger define automaticamente)
PORT=3000

# Chave de API do Datajud (opcional)
# Se omitida, a aplicação usará a chave pública padrão do CNJ
DATAJUD_API_KEY=sua_chave_do_datajud_aqui

# Integração opcional com Supabase (para persistência em nuvem)
# Se omitidas, a aplicação salvará os dados em arquivos JSON na pasta ./data
SUPABASE_URL=https://seu-projeto-id.supabase.co
SUPABASE_KEY=sua_chave_anon_ou_service_role_aqui
